// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  ACTIVE
  SCALING
  PAUSED
}

enum UserRole {
  ADMIN
  EDITOR
}

model User {
  id          String   @id @default(cuid())
  clerkUserId String   @unique
  email       String   @unique
  name        String?
  role        UserRole @default(EDITOR)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Project {
  id            String        @id @default(cuid())
  title         String
  thumbnailUrl  String?
  description   String?
  status        ProjectStatus @default(ACTIVE)
  category      String?
  robloxLink    String?
  robloxPlaceId String?
  visits        BigInt        @default(0)
  favorites     Int           @default(0)
  featured      Boolean       @default(false)
  visible       Boolean       @default(true)
  sortOrder     Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([visible, sortOrder])
  @@index([robloxPlaceId])
}

model Metric {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String
  value     String
  trend     String?
  visible   Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([visible, sortOrder])
}

model OperatingSignal {
  id          String   @id @default(cuid())
  title       String
  subtitle    String?
  description String?
  visible     Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([visible, sortOrder])
}

model CredibilityItem {
  id        String   @id @default(cuid())
  title     String
  body      String
  visible   Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([visible, sortOrder])
}

model LeadershipMember {
  id        String   @id @default(cuid())
  role      String
  name      String
  bio       String?
  avatarUrl String?
  visible   Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([visible, sortOrder])
}

model NetworkLink {
  id          String   @id @default(cuid())
  label       String
  url         String
  description String?
  visible     Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([visible, sortOrder])
}

model SiteSettings {
  id              Int      @id @default(1)
  brand           String   @default("AVNT")
  logoUrl         String?
  heroTitle       String   @default("We Build Worlds That Define Culture")
  heroSubtitle    String   @default("AVNT is a Roblox game studio and creative collective pushing the boundaries of digital entertainment.")
  heroCta         String   @default("Explore Our Games")
  aboutTitle      String   @default("About AVNT")
  aboutBody       String   @default("We are a team of visionary creators building the next generation of Roblox experiences.")
  metricsTitle    String   @default("Millions Engage With Our Portfolio")
  metricsSubtitle String   @default("Real-time data from our live games.")
  gamesTitle      String   @default("Our Games")
  gamesSubtitle   String   @default("Explore our portfolio of immersive Roblox experiences.")
  credTitle       String   @default("Why AVNT")
  teamTitle       String   @default("Leadership")
  teamSubtitle    String   @default("The minds behind the movement.")
  networkTitle    String   @default("Join the Network")
  networkSubtitle String   @default("Connect with us across platforms.")
  footerText      String   @default("© 2024 AVNT. All rights reserved.")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
